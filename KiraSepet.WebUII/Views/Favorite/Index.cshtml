@model List<KiraSepet.WebUII.Models.FavoriteItem>

<div class="container mt-5">

    <h2 class="mb-4">Favorilerim ❤️</h2>

    <table class="table table-hover table-striped align-middle shadow-sm">

        <tr>
            <th>Ürün</th>
            <th>Fiyat</th>
            <th>İşlem</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.SalePrice ₺</td>
                <td>
                    <a href="/Favorite/RemoveFromFavorite/@item.ProductId"
                       class="btn btn-danger btn-sm">
                        Favoriden Kaldır
                    </a>
                </td>
            </tr>
        }

    </table>

</div>
