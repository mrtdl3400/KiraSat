@model List<KiraSepet.WebUII.Models.FavoriteItem>

<div class="container mt-5">

    <h2 class="mb-4">Favorilerim ❤️</h2>

    @if (TempData["FavoriteMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["FavoriteMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-hover table-striped align-middle shadow-sm">

        <tr>
            <th>Ürün</th>
            <th>Fiyat</th>
            <th>İşlem</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a href="/Product/ProductDetails/@item.ProductId" class="text-decoration-none fw-bold text-dark">
                        @item.ProductName
                    </a>
                </td>
                <td>@item.SalePrice ₺</td>
                <td>
                    <a href="/Favorite/RemoveFromFavorite/@item.ProductId"
                       class="btn btn-danger btn-sm">
                        Favoriden Kaldır
                    </a>
                </td>
            </tr>
        }

    </table>

</div>
