@using KiraSepet.EntityLayer
@model List<Product>

@{
    ViewData["Title"] = "Satıcı Paneli";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Satıcı Paneli</h2>
            <p class="text-muted mb-0">@ViewBag.BusinessName</p>
        </div>
        <a class="btn btn-outline-secondary" href="/Product/Index">Mağazaya Git</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <strong>Yeni Ürün Ekle</strong>
        </div>

        <div class="card-body">
            <form asp-controller="Seller" asp-action="AddProduct" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Ürün Adı</label>
                        <input class="form-control" name="ProductName" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Kategori</label>
                        <select class="form-select" name="CategoryId" required>
                            <option value="">Kategori seç</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id">@category.CategoryName</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Satış Fiyatı (₺)</label>
                        <input class="form-control" type="number" name="SalePrice" min="0" step="0.01" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Stok Adedi</label>
                        <input class="form-control" type="number" name="StockCount" min="0" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Marka</label>
                        <input class="form-control" name="Brand" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Görsel URL</label>
                        <input class="form-control" name="ImageUrl" placeholder="/resim/ornek.jpg" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Şehir</label>
                        <input class="form-control" name="City" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">İlçe</label>
                        <input class="form-control" name="District" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Adres</label>
                        <input class="form-control" name="Address" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Açıklama</label>
                        <textarea class="form-control" name="Description" rows="2"></textarea>
                    </div>

                    <div class="col-md-3">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" name="IsRentable" value="true" id="isRentable" />
                            <label class="form-check-label" for="isRentable">Kiralanabilir</label>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Günlük Kira (₺)</label>
                        <input class="form-control" type="number" name="DailyPrice" min="0" step="0.01" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Kiralama Tipi</label>
                        <input class="form-control" name="RentType" placeholder="Günlük" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-primary w-100" type="submit">Ürünü Ekle</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <strong>Ürünlerim (@Model.Count)</strong>
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Ürün</th>
                        <th>Kategori</th>
                        <th>Satış Fiyatı</th>
                        <th>Günlük Kira</th>
                        <th>Stok</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td>@product.ProductName</td>
                                <td>@product.Category?.CategoryName</td>
                                <td>@product.SalePrice.ToString("N2") ₺</td>
                                <td>
                                    @(product.IsRentable && product.DailyPrice.HasValue
                                        ? product.DailyPrice.Value.ToString("N2") + " ₺"
                                        : "-")


                                </td>
                                <td>@product.StockCount</td>

                                <td>
                                    <a asp-action="EditProduct"
                                       asp-route-id="@product.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Düzenle
                                    </a>
                                    <form asp-action="DeleteProduct" asp-route-id="@product.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Bu ürünü yayından kaldırmak istediğine emin misin?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                                    </form>
                                </td>
                            </tr>


                        }

                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Henüz ürün eklemedin.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
