@model List<KiraSepet.EntityLayer.CartItem>

<div class="container mt-5">

    <h2 class="mb-4">Ödeme Sayfası 💳</h2>

    <div class="card shadow p-4">

        <div class="mb-3">
            <label>Kart Üzerindeki İsim</label>
            <input type="text" id="cardHolderName" class="form-control" placeholder="Mert Dalkıran">
            <div class="form-check mt-2">
                <input type="checkbox" id="rememberCardHolder" class="form-check-input">
                <label for="rememberCardHolder" class="form-check-label">
                    Kart üzerindeki ismi hatırla
                </label>
            </div>
        </div>

        <div class="mb-3">
            <label>Kart Numarası</label>
            <input type="text" class="form-control" placeholder="0000 0000 0000 0000">
        </div>

        <div class="row">

            <div class="col-md-6 mb-3">
                <label>Son Kullanma Tarihi</label>
                <input type="text" class="form-control" placeholder="12/30">
            </div>

            <div class="col-md-6 mb-3">
                <label>CVV</label>
                <input type="text" class="form-control" placeholder="123">
            </div>

        </div>

        <hr />

        <h4 class="text-end">
            Toplam:
            <span class="text-success">
                @(ViewBag.TotalPrice != null && Convert.ToDecimal(ViewBag.TotalPrice) > 0
    ? ViewBag.TotalPrice
    : ViewBag.CartTotal)
            </span>
        </h4>

        <div class="text-end mt-3">

            <a href="/Payment/CompletePayment" class="btn btn-success btn-lg">
                Ödemeyi Tamamla
            </a>

        </div>

    </div>

</div>

<script>
    const cardHolderName = document.getElementById('cardHolderName');
    const rememberCardHolder = document.getElementById('rememberCardHolder');
    const savedCardHolderName = localStorage.getItem('kiraSepetCardHolderName');

    if (savedCardHolderName) {
        cardHolderName.value = savedCardHolderName;
        rememberCardHolder.checked = true;
    }

    rememberCardHolder.addEventListener('change', function () {
        if (this.checked) {
            localStorage.setItem('kiraSepetCardHolderName', cardHolderName.value);
        } else {
            localStorage.removeItem('kiraSepetCardHolderName');
        }
    });

    cardHolderName.addEventListener('input', function () {
        if (rememberCardHolder.checked) {
            localStorage.setItem('kiraSepetCardHolderName', this.value);
        }
    });
</script>
