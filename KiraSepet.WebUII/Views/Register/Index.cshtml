@model KiraSepet.DataAccessLayer.AppUser

<div class="register-page">
    <div class="register-panel">
        <div class="register-visual">
            <div class="register-logo">KS</div>
            <h2>KiraSat'a Katıl</h2>
            <p>
                Ürünleri keşfet, favorilerine kaydet, sepete ekle ve güvenle kirala veya satın al.
            </p>

            <div class="register-benefits">
                <span>Hızlı alışveriş</span>
                <span>Favori ürünler</span>
                <span>Güvenli ödeme</span>
            </div>
        </div>

        <div class="register-form-card">
            <h1>Kayıt Ol</h1>
            <p class="register-subtitle">Hesabını oluştur, KiraSat deneyimine başla.</p>

            <form method="post">
                <div class="form-group">
                    <label>Ad Soyad</label>
                    <input asp-for="NameSurname" class="form-control" placeholder="Adınızı ve soyadınızı yazın" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="ornek@mail.com" />
                </div>

                <div class="form-group">
                    <label>Şifre</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Güçlü bir şifre oluşturun" />
                </div>

                <button type="submit" class="register-btn">
                    Kayıt Ol
                </button>

                <div class="register-login-link">
                    Zaten hesabın var mı?
                    <a href="/Login/Index">Giriş Yap</a>
                </div>
            </form>
        </div>
    </div>
</div>
