@model KiraSepet.DataAccessLayer.AppUser

<div class="register-page">
    <div class="register-panel">
        <div class="register-visual">
            <div class="register-logo">KS</div>
            <h2>KiraSat'a Katıl</h2>
            <p>
                Ürünleri keşfet, favorilerine kaydet, sepete ekle ve güvenle kirala veya satın al.
            </p>

            <div class="register-benefits">
                <span>Hızlı alışveriş</span>
                <span>Favori ürünler</span>
                <span>Güvenli ödeme</span>
            </div>
        </div>

        <div class="register-form-card">
            <h1>Kayıt Ol</h1>
            <p class="register-subtitle">Hesabını oluştur, KiraSat deneyimine başla.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label>Ad Soyad</label>
                    <input asp-for="NameSurname" class="form-control" placeholder="Adınızı ve soyadınızı yazın" />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="ornek@mail.com" />
                </div>

                <div class="form-group">
                    <label>Şifre</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Güçlü bir şifre oluşturun" />
                </div>

                <div class="form-group">
                    <label>Cinsiyet <span class="optional-label">(isteğe bağlı)</span></label>
                    <div class="gender-options">
                        <label><input type="radio" name="Gender" value="Kadın" /> Kadın</label>
                        <label><input type="radio" name="Gender" value="Erkek" /> Erkek</label>
                    </div>
                </div>

                <div class="consent-list">
                    <label class="consent-item"><input type="checkbox" name="marketingConsent" /> <span>Kampanya ve avantajlı tekliflerle ilgili elektronik ileti almak istiyorum.</span></label>
                    <label class="consent-item"><input type="checkbox" name="personalDataConsent" value="true" /> <span>Kişisel verilerimin işlenmesine yönelik aydınlatma metnini okudum ve anladım.</span></label>
                    <label class="consent-item"><input type="checkbox" name="termsConsent" value="true" /> <span>Kullanım koşullarını ve gizlilik politikasını kabul ediyorum.</span></label>
                </div>

                <button type="submit" class="register-btn">
                    Kayıt Ol
                </button>

                <div class="register-login-link">
                    Zaten hesabın var mı?
                    <a href="/Login/Index">Giriş Yap</a>
                </div>
            </form>
        </div>
    </div>
</div>
