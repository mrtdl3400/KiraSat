@model KiraSepet.EntityLayer.Product

<div class="product-detail-page">
    <div class="product-detail-card">

        <div class="product-image-area">
            <img src="@Model.ImageUrl" alt="@Model.ProductName" />
        </div>

        <div class="product-info-area">
            <span class="category-badge">@Model.Category?.CategoryName</span>

            <h1>@Model.ProductName</h1>

            @if (Model.Business != null)
            {
                <a href="/SellerProfile/Index?businessId=@Model.Business.Id" class="business-profile-card">
                    <span class="business-profile-icon">🏪</span>
                    <span>
                        <small>Bu ürünün işletmesi</small>
                        <strong>@Model.Business.CompanyName</strong>
                    </span>
                    <b>Profili gör →</b>
                </a>
            }

            <p class="description">
                @Model.Description
            </p>

            <div class="price-box">
                <div>
                    <small>Satış Fiyatı</small>
                    <strong>@Model.SalePrice ₺</strong>
                </div>

                <div>
                    <small>Günlük Kiralama</small>
                    <strong>@Model.DailyPrice ₺</strong>
                </div>
            </div>

            @if (Model.IsRentable)
            {
                <div class="rent-panel">
                    <div class="rent-panel-title">
                        Kiralama Tarihi Seç
                    </div>

                    <div class="rent-date-grid">
                        <input type="date" id="startDate"
                               class="form-control"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")" />

                        <input type="date" id="endDate"
                               class="form-control"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <input type="hidden" id="hiddenTotalPrice" value="0" />

                    <button type="button" class="btn btn-primary w-100 mt-3" onclick="calculateRent()">
                        Kiralama Ücretini Hesapla
                    </button>

                    <div class="alert alert-info mt-3" id="rentResult" style="display:none;"></div>
                </div>
            }

            <div class="product-meta-grid">
                <div class="product-meta-item">
                    <span>Stok durumu</span>
                    <strong>@Model.StockCount adet</strong>
                </div>
                <div class="product-meta-item">
                    <span>Kiralanabilir mi?</span>
                    @if (Model.IsRentable)
                    {
                        <strong><span class="rent-yes">Evet</span></strong>
                    }
                    else
                    {
                        <strong><span class="rent-no">Hayır</span></strong>
                    }
                </div>
            </div>

            <div class="product-actions">
                <div class="product-primary-actions">
                    @if (Context.Session.GetString("UserName") == null)
                    {
                        <a href="/Login/Index" class="product-action-btn buy-action" onclick="alert('Satın alma işlemi için lütfen giriş yapın veya kaydolun!')">Satın Al</a>
                    }
                    else
                    {
                        <a href="/Payment/Index?productId=@Model.Id&type=buy" class="product-action-btn buy-action">Satın Al</a>
                    }

                    @if (Model.IsRentable)
                    {
                        @if (Context.Session.GetString("UserName") == null)
                        {
                            <a href="/Login/Index" class="product-action-btn rent-action" onclick="alert('Kiralama işleminizi yapmak için lütfen giriş yapın veya kaydolun!')">Kirala</a>
                        }
                        else
                        {
                            <a href="javascript:void(0);" class="product-action-btn rent-action" onclick="goToPayment(@Model.Id)">Kirala</a>
                        }
                    }
                </div>

                @if (Model.BusinessId != null)
                {
                    <a href="/RentalMessage/Start?productId=@Model.Id" class="product-message-action">
                        <span>✉</span>
                        @(Model.Business?.CompanyName ?? "Satıcı") işletmesine mesaj gönder
                    </a>
                }

                <a href="/Product/Index" class="product-back-action">← Listeye dön</a>
            </div>
            </div>
        </div>

   
</div>

@if (TempData["CommentError"] != null)
{
    <div class="alert alert-warning">
        @TempData["CommentError"]
    </div>
}

@if (TempData["RatingError"] != null)
{
    <div class="alert alert-warning">
        @TempData["RatingError"]
    </div>
}
@if (ViewBag.RatingCount > 0)
{
    <h4>⭐ Ortalama Puan: @ViewBag.AverageRating.ToString("0.0") / 5</h4>
    <p>Toplam @ViewBag.RatingCount değerlendirme</p>
}
else
{
    <p>Bu ürüne henüz puan verilmedi.</p>
}
<div class="comment-area">
    <h3>Ürünü Puanla</h3>

    <form method="post" action="/Product/AddComment">
        <input type="hidden" name="ProductId" value="@Model.Id" />

        

        <label class="mt-3">Puanınız</label>
        <select name="Rating" class="form-control mt-2">
            <option value="5">⭐⭐⭐⭐⭐ - Çok İyi</option>
            <option value="4">⭐⭐⭐⭐ - İyi</option>
            <option value="3">⭐⭐⭐ - Orta</option>
            <option value="2">⭐⭐ - Kötü</option>
            <option value="1">⭐ - Çok Kötü</option>
        </select>

        

        <button type="submit" class="btn btn-dark mt-3">
            Puan Ver
        </button>
    </form>
</div>



