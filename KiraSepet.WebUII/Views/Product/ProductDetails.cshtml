<hr />


<hr />





<script>
       

    function calculateRent() {

            const startValue = document.getElementById("startDate").value;
    const endValue = document.getElementById("endDate").value;

    if (!startValue || !endValue) {
        document.getElementById("rentResult").style.display = "block";
        document.getElementById("rentResult").innerHTML = "Lütfen başlangıç ve bitiş tarihini seçiniz!";
        return;
    }

       const start = new Date(startValue);

       const end = new Date(endValue);

        const diffTime = end - start;

        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

      const dailyPrice = parseFloat("@Model.DailyPrice".replace(",", "."));

        const total = diffDays * dailyPrice;

        const resultDiv = document.getElementById("rentResult");

           if (diffDays > 0) {

        resultDiv.style.display = "block";

            resultDiv.innerHTML = `
    <div class="p-3 rounded shadow-sm bg-light">

        <h5 class="text-success">
            💰 Toplam Ücret: <span id="totalPrice">${total}</span> ₺
        </h5>
    </div>
    `;

    document.getElementById("hiddenTotalPrice").value = total;
    }
        else {

            resultDiv.style.display = "block";

            resultDiv.innerHTML =
                "Lütfen geçerli tarih seçiniz!";
        }
    }
</script>

<script>
    function goToPayment(productId) {

            var totalElement = document.getElementById("totalPrice");

            

    

        

        var startDate = document.getElementById("startDate").value;
        var endDate = document.getElementById("endDate").value;

            if (startDate == "" || endDate == "") {
        Swal.fire({
            icon: 'warning',
            title: 'Tarih seçilmedi',
            text: 'Lütfen başlangıç ve bitiş tarihini seçin.',
            confirmButtonText: 'Tamam'
        });
        return;
    }

          var total = document.getElementById("hiddenTotalPrice").value;

            console.log(total);

    window.location.href =
    "/Payment/Index?productId=" + productId +
    "&type=rent" +
    "&startDate=" + startDate +
    "&endDate=" + endDate +
    "&totalPrice=" + encodeURIComponent(total);
    }


    
    function loginAlert() {
        Swal.fire({
            icon: 'warning',
            title: 'Giriş yapmanız gerekiyor',
            text: 'Kiralama işlemi için giriş yapmalısınız.',
            showCancelButton: true,
            confirmButtonText: 'Giriş Yap',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Login/Index';
            }
        });
    }
</script>


