@model KiraSepet.EntityLayer.Product

<div class="product-detail-page">
    <div class="product-detail-card">

        <div class="product-image-area">
            <img src="@Model.ImageUrl" alt="@Model.ProductName" />
        </div>

        <div class="product-info-area">
            <span class="category-badge">@Model.Category?.CategoryName</span>

            <h1>@Model.ProductName</h1>

            <p class="description">
                @Model.Description
            </p>

            <div class="price-box">
                <div>
                    <small>Satış Fiyatı</small>
                    <strong>@Model.SalePrice ₺</strong>
                </div>

                <div>
                    <small>Günlük Kiralama</small>
                    <strong>@Model.DailPrice ₺</strong>
                </div>
            </div>

            @if (Model.IsRentable)
            {
                <div class="rent-panel">
                    <div class="rent-panel-title">
                        Kiralama Tarihi Seç
                    </div>

                    <div class="rent-date-grid">
                        <input type="date" id="startDate"
                               class="form-control"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")" />

                        <input type="date" id="endDate"
                               class="form-control"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <input type="hidden" id="hiddenTotalPrice" value="0" />

                    <button type="button" class="btn btn-primary w-100 mt-3" onclick="calculateRent()">
                        Kiralama Ücretini Hesapla
                    </button>

                    <div class="alert alert-info mt-3" id="rentResult" style="display:none;"></div>
                </div>
            }

            <p><b>Stok:</b> @Model.StockCount adet</p>

            <p>
                <b>Kiralanabilir mi?</b>
                @if (Model.IsRentable)
                {
                    <span class="rent-yes">Evet</span>
                }
                else
                {
                    <span class="rent-no">Hayır</span>
                }
            </p>
            @if (Context.Session.GetString("UserName") == null)
            {
                <a href="/Login/Index"
                   class="btn btn-dark"
                   onclick="alert('Satın alma işlemi için lütfen giriş yapın veya kaydolun!')">
                    Satın Al
                </a>
            }
            else
            {
                <a href="/Payment/Index?productId=@Model.Id&type=buy"
                   class="btn btn-dark">
                    Satın Al
                </a>
            }

                @if (Model.IsRentable)
                {
                    @if (Context.Session.GetString("UserName") == null)
                    {
                        <a href="/Login/Index"
                           class="btn btn-success ms-2"
                           onclick="alert('Kiralama işleminizi yapmak için lütfen giriş yapın veya kaydolun!')">
                            Kirala
                        </a>
                    }
                    else
                    {
                        <a href="javascript:void(0);"
                           class="btn btn-success ms-2"
                           onclick="goToPayment(@Model.Id)">
                            Kirala
                        </a>
                    }
                }
                <a href="/Product/Index" class="btn-back">Listeye Dön</a>
            </div>
        </div>

   
</div>

@if (TempData["CommentError"] != null)
{
    <div class="alert alert-warning">
        @TempData["CommentError"]
    </div>
}

@if (TempData["RatingError"] != null)
{
    <div class="alert alert-warning">
        @TempData["RatingError"]
    </div>
}
@if (ViewBag.RatingCount > 0)
{
    <h4>⭐ Ortalama Puan: @ViewBag.AverageRating.ToString("0.0") / 5</h4>
    <p>Toplam @ViewBag.RatingCount değerlendirme</p>
}
else
{
    <p>Bu ürüne henüz puan verilmedi.</p>
}
<div class="comment-area">
    <h3>Ürünü Puanla</h3>

    <form method="post" action="/Product/AddComment">
        <input type="hidden" name="ProductId" value="@Model.Id" />

        

        <label class="mt-3">Puanınız</label>
        <select name="Rating" class="form-control mt-2">
            <option value="5">⭐⭐⭐⭐⭐ - Çok İyi</option>
            <option value="4">⭐⭐⭐⭐ - İyi</option>
            <option value="3">⭐⭐⭐ - Orta</option>
            <option value="2">⭐⭐ - Kötü</option>
            <option value="1">⭐ - Çok Kötü</option>
        </select>

        

        <button type="submit" class="btn btn-dark mt-3">
            Puan Ver
        </button>
    </form>
</div>



<style>
    .product-detail-page {
        min-height: 80vh;
        background: #f5f7fb;
        padding: 50px;
    }

    .product-detail-card {
        max-width: 1100px;
        margin: auto;
        background: white;
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.12);
        display: grid;
        grid-template-columns: 1fr 1fr;
        overflow: hidden;
    }

    .product-image-area {
        background: #eef2ff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
    }

        .product-image-area img {
            max-width: 100%;
            max-height: 420px;
            object-fit: contain;
            border-radius: 20px;
        }

    .product-info-area {
        padding: 50px;
    }

    .category-badge {
        display: inline-block;
        background: #111827;
        color: white;
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .product-info-area h1 {
        font-size: 42px;
        font-weight: 900;
        color: #111827;
        margin-bottom: 20px;
    }

    .description {
        color: #4b5563;
        font-size: 17px;
        line-height: 1.7;
        margin-bottom: 30px;
    }

    .price-box {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 25px;
    }

        .price-box div {
            background: #f3f4f6;
            padding: 18px;
            border-radius: 18px;
        }

        .price-box small {
            color: #6b7280;
            display: block;
            margin-bottom: 8px;
        }

        .price-box strong {
            font-size: 24px;
            color: #111827;
        }

    .rent-yes {
        background: #16a34a;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: bold;
    }

    .rent-no {
        background: #dc2626;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: bold;
    }

    .rent-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        margin: 20px 0 24px;
        padding: 20px;
    }

    .rent-panel-title {
        color: #111827;
        font-size: 20px;
        font-weight: 900;
        margin-bottom: 14px;
    }

    .rent-date-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: 1fr 1fr;
    }

        .rent-date-grid .form-control {
            border-radius: 12px;
            height: 46px;
        }

    .detail-buttons {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .btn-buy,
    .btn-back {
        padding: 14px 22px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-buy {
        background: #111827;
        color: white;
    }

    .btn-back {
        background: #e5e7eb;
        color: #111827;
    }

    comment-box {
        background: #f3f4f6;
        padding: 20px;
        border-radius: 18px;
        margin-top: 20px;
    }

    .comment-box h5 {
        font-weight: bold;
        margin-bottom: 5px;
    }

    .comment-box small {
        color: gray;
    }

    .comment-box p {
        margin-top: 10px;
    }
</style>





<hr />


<hr />





<script>
       

    function calculateRent() {

            const startValue = document.getElementById("startDate").value;
    const endValue = document.getElementById("endDate").value;

    if (!startValue || !endValue) {
        document.getElementById("rentResult").style.display = "block";
        document.getElementById("rentResult").innerHTML = "Lütfen başlangıç ve bitiş tarihini seçiniz!";
        return;
    }

       const start = new Date(startValue);

       const end = new Date(endValue);

        const diffTime = end - start;

        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

      const dailyPrice = parseFloat("@Model.DailPrice".replace(",", "."));

        const total = diffDays * dailyPrice;

        const resultDiv = document.getElementById("rentResult");

           if (diffDays > 0) {

        resultDiv.style.display = "block";

            resultDiv.innerHTML = `
    <div class="p-3 rounded shadow-sm bg-light">

        <h5 class="text-success">
            💰 Toplam Ücret: <span id="totalPrice">${total}</span> ₺
        </h5>
    </div>
    `;

    document.getElementById("hiddenTotalPrice").value = total;
    }
        else {

            resultDiv.style.display = "block";

            resultDiv.innerHTML =
                "Lütfen geçerli tarih seçiniz!";
        }
    }
</script>

<script>
    function goToPayment(productId) {

            var totalElement = document.getElementById("totalPrice");

            

    

        

        var startDate = document.getElementById("startDate").value;
        var endDate = document.getElementById("endDate").value;

            if (startDate == "" || endDate == "") {
        Swal.fire({
            icon: 'warning',
            title: 'Tarih seçilmedi',
            text: 'Lütfen başlangıç ve bitiş tarihini seçin.',
            confirmButtonText: 'Tamam'
        });
        return;
    }

          var total = document.getElementById("hiddenTotalPrice").value;

            console.log(total);

    window.location.href =
    "/Payment/Index?productId=" + productId +
    "&type=rent" +
    "&startDate=" + startDate +
    "&endDate=" + endDate +
    "&totalPrice=" + encodeURIComponent(total);
    }


    
    function loginAlert() {
        Swal.fire({
            icon: 'warning',
            title: 'Giriş yapmanız gerekiyor',
            text: 'Kiralama işlemi için giriş yapmalısınız.',
            showCancelButton: true,
            confirmButtonText: 'Giriş Yap',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Login/Index';
            }
        });
    }
</script>


