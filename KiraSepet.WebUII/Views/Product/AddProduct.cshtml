@model KiraSepet.EntityLayer.Product

<h2>Ürün Ekle</h2>
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}


   <form method="post" enctype="multipart/form-data">

    <label>Ürün Adı</label>
    <input asp-for="ProductName" class="form-control" />
    <br />

    <label>Fiyat</label>
    <input asp-for="SalePrice" class="form-control" />
    <br />
    <div class="mb-3">
    <label>Şehir</label>
    <input type="text" asp-for="City" class="form-control" />
</div>

<div class="mb-3">
    <label>İlçe</label>
    <input type="text" asp-for="District" class="form-control" />
</div>

<div class="mb-3">
    <label>Adres</label>
    <textarea asp-for="Address" class="form-control"></textarea>
</div>


    <label>Günlük Kiralama Fiyatı</label>
    <input asp-for="DailyPrice" class="form-control" />
    <label>Ürün Görseli</label>
    <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />

    <div class="mb-3">
        <label>Satış Stoğu</label>
        <input type="number" asp-for="StockCount" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Kiralama Stoğu</label>
        <input type="number" asp-for="RentalStockCount" class="form-control" min="0" />
    </div>
    <br />
    <br />
    <label>Kiralama Türü</label>
    <select asp-for="RentType" class="form-control">
        <option value="Günlük">Günlük</option>
        <option value="Aylık">Aylık</option>
        <option value="Yıllık">Yıllık</option>
    </select>
    <br />
    <br />
    <label>Kiralanabilir mi?</label>
    <input type="checkbox" asp-for="IsRentable" />

    <br />
    <label>Marka</label>
    <input type="text" name="Brand" class="form-control" />
    <br />

   

    <div class="mb-3">
        <label>Açıklama</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <br />

    <label>Kategori</label>
    <select asp-for="CategoryId" class="form-control">
        @foreach (var item in ViewBag.Categories)
        {
            <option value="@item.Id">@item.CategoryName</option>
        }
    </select>
    <br />

    <button type="submit" class="btn btn-primary">Kaydet</button>

</form>

   

















