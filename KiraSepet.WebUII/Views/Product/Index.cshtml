@using Microsoft.AspNetCore.Http
@{
    var isAdmin = Context.Session.GetString("UserRole") == "Admin";
}
<div class="container-fluid px-4">

    <div class="row mb-4">

        <div class="col-12">
            
            <div class="d-flex justify-content-between align-items-center mb-4">

                <h2 class="product-list-title">
                    Ürün Listesi
                </h2>

                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a href="/Product/AddProduct" class="product-add-btn">+ Ürün Ekle</a>
                }

            </div>

            
            <div class="product-list-hero">

                <h1 class="display-3 fw-bold">KiraSat</h1>

                <p class="fs-4 mt-3">
                    Satın al, ihtiyacın kadar kirala.
                </p>

                <p class="mb-0 opacity-75">
                    Ürünleri keşfet, favorilerine ekle, sepete at veya kirala.
                </p>
            </div>

                
            

        

            <form method="get" class="product-filter-bar">

                <input type="text"
                       name="p"
                       class="form-control"
                       placeholder="Ürün ara..." />

                <input type="text"
                       name="city"
                       class="form-control"
                       placeholder="Şehir ara..." />

                <input type="text"
                       name="district"
                       class="form-control"
                       placeholder="İlçe ara..." />

                <button class="product-filter-button">
                    Ara
                </button>

            </form>


            <div class="product-grid">
                @foreach (var item in Model)
                {
                    <div class="product-card">
                        <div class="product-image-wrap">
                            <a href="/Product/ProductDetails/@item.Id" class="product-image">
                                <img src="@item.ImageUrl" alt="@item.ProductName" />
                            </a>

                            @if (Context.Session.GetString("UserName") == null)
                            {
                                <button type="button"
                                        class="favorite-heart"
                                        onclick="loginAlert()"
                                        title="Favorilere ekle">
                                    ♥
                                </button>
                            }
                            else
                            {
                                <a href="/Favorite/AddToFavorite/@item.Id"
                                   class="favorite-heart"
                                   title="Favorilere ekle">
                                    ♥
                                </a>
                            }
                        </div>

                        <div class="product-body">
                            <div class="product-category">
                                @(item.Category != null ? item.Category.CategoryName : "Kategori Yok")
                            </div>

                            <a href="/Product/ProductDetails/@item.Id" class="product-title">
                                @item.ProductName
                            </a>

                            <div class="product-brand">@item.Brand</div>

                            @{
                                var averageRatings = ViewBag.ProductAverageRatings as System.Collections.Generic.Dictionary<int, double>;
                                var ratingCounts = ViewBag.ProductRatingCounts as System.Collections.Generic.Dictionary<int, int>;

                                double averageRating = 0;
                                int ratingCount = 0;

                                if (averageRatings != null)
                                {
                                    averageRatings.TryGetValue(item.Id, out averageRating);
                                }

                                if (ratingCounts != null)
                                {
                                    ratingCounts.TryGetValue(item.Id, out ratingCount);
                                }

                                var roundedRating = (int)Math.Round(averageRating);
                            }

                            <div class="product-rating">
                                <span class="rating-number">@averageRating.ToString("0.0")</span>

                                <span class="rating-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= roundedRating)
                                        {
                                            <span class="star filled">★</span>
                                        }
                                        else
                                        {
                                            <span class="star">★</span>
                                        }
                                    }
                                </span>

                                <span class="rating-count">(@ratingCount)</span>
                            </div>

                            <div class="product-location">
                                @item.City / @item.District
                            </div>

                            <div class="product-prices">
                                <div>
                                    <span>Günlük kira</span>
                                    <strong>@item.DailyPrice ₺</strong>
                                </div>
                                <div>
                                    <span>Satış</span>
                                    <strong>@item.SalePrice ₺</strong>
                                </div>
                            </div>

                            <div class="product-meta">
                                @if (item.StockCount <= 0)
                                {
                                    <span class="stock-badge danger">Satış tükendi</span>
                                }
                                else
                                {
                                    <span class="stock-badge">Satış: @item.StockCount</span>
                                }

                                @if (item.IsRentable && item.RentalStockCount > 0)
                                {
                                    <span class="rent-badge">Kiralık: @item.RentalStockCount</span>
                                }
                                else
                                {
                                    <span class="rent-badge danger">Kiralanamaz</span>
                                }
                            </div>

                            <div class="product-actions">
                                <a href="/Product/ProductDetails/@item.Id" class="btn btn-info btn-sm">Detay</a>

                                @if (Context.Session.GetString("UserName") == null)
                                {
                                    <button type="button" class="btn btn-success btn-sm" onclick="loginAlert()">Sepet</button>
                                    
                                }
                                else
                                {
                                    <a href="/Cart/AddToCart/@item.Id" class="btn btn-success btn-sm">Sepet</a>
                                    
                                }

                                @if (Context.Session.GetString("UserRole") == "Admin")
                                {
                                    @if (Context.Session.GetString("UserRole") == "Admin")
                                    {
                                        <a href="/Product/UpdateProduct/@item.Id" class="btn btn-warning btn-sm">Güncelle</a>

                                        <form method="post"
                                              action="/Product/DeleteProduct/@item.Id"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                                Sil
                                            </button>
                                        </form>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <script>
                            function loginAlert() {
                                Swal.fire({
                                    icon: 'warning',
                                    title: 'Giriş yapmanız gerekiyor',
                                    text: 'Bu işlemi yapmak için giriş yapmalısınız.',
                                    showCancelButton: true,
                                    confirmButtonText: 'Giriş Yap',
                                    cancelButtonText: 'Vazgeç'
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '/Login/Index';
                                    }
                                });
                            }
            </script>

        </div>
    </div>
</div>

<style>
    .product-list-title {
        color: #172033;
        font-size: 30px;
        font-weight: 900;
        letter-spacing: -.7px;
        margin: 0;
    }

    .product-add-btn {
        background: #f97316;
        border-radius: 10px;
        box-shadow: 0 8px 18px rgba(249, 115, 22, .2);
        color: white;
        font-weight: 800;
        padding: 10px 15px;
        text-decoration: none;
    }

    .product-list-hero {
        background: linear-gradient(135deg, #f97316 0%, #fb923c 62%, #ffb347 100%);
        border-radius: 22px;
        box-shadow: 0 16px 30px rgba(249, 115, 22, .18);
        color: white;
        margin-bottom: 24px;
        overflow: hidden;
        padding: 44px 28px;
        position: relative;
        text-align: center;
    }

    .product-list-hero::after {
        background: rgba(255,255,255,.16);
        border-radius: 50%;
        content: "";
        height: 260px;
        position: absolute;
        right: -80px;
        top: -140px;
        width: 260px;
    }

    .product-list-hero h1,
    .product-list-hero p {
        position: relative;
        z-index: 1;
    }

    .product-list-hero h1 {
        font-size: clamp(40px, 5vw, 58px);
        font-weight: 900;
        letter-spacing: -1.6px;
        margin: 0;
    }

    .product-list-hero .fs-4 {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .product-list-hero .opacity-75 {
        opacity: .9 !important;
    }

    .product-filter-bar {
        align-items: center;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, .05);
        display: flex;
        gap: 10px;
        margin-bottom: 26px;
        padding: 10px;
    }

    .product-filter-bar .form-control {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        box-shadow: none;
        min-width: 0;
    }

    .product-filter-button {
        background: #172033;
        border: 0;
        border-radius: 10px;
        color: white;
        font-weight: 800;
        padding: 10px 18px;
    }

    @@media (max-width: 768px) {
        .product-filter-bar {
            align-items: stretch;
            flex-direction: column;
        }

        .product-filter-button {
            width: 100%;
        }
    }
</style>
