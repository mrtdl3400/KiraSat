@using Microsoft.AspNetCore.Http
@{
    var isAdmin = Context.Session.GetString("UserRole") == "Admin";
}
<div class="container-fluid px-4">

    <div class="row mb-4">

        <div class="col-12">
            
            <div class="d-flex justify-content-between align-items-center mb-4">

                <h2 class="fw-bold text-primary">
                    Ürün Listesi
                </h2>

                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a href="/Product/AddProduct" class="btn btn-primary">Ürün Ekle</a>
                }

            </div>

            
            <div class="p-5 mb-4 rounded-4 shadow-sm text-center text-white"
                 style="background: linear-gradient(135deg, #0d6efd, #6610f2);">

                <h1 class="display-3 fw-bold">KiraSat</h1>

                <p class="fs-4 mt-3">
                    Satın al, ihtiyacın kadar kirala.
                </p>

                <p class="mb-0 opacity-75">
                    Ürünleri keşfet, favorilerine ekle, sepete at veya kirala.
                </p>
            </div>

                
            

        

            <form method="get" class="d-flex gap-2 mb-4">

                <input type="text"
                       name="p"
                       class="form-control"
                       placeholder="Ürün ara..." />

                <input type="text"
                       name="city"
                       class="form-control"
                       placeholder="Şehir ara..." />

                <input type="text"
                       name="district"
                       class="form-control"
                       placeholder="İlçe ara..." />

                <button class="btn btn-primary">
                    Ara
                </button>

            </form>


            <div class="product-grid">
                @foreach (var item in Model)
                {
                    <div class="product-card">
                        <div class="product-image-wrap">
                            <a href="/Product/ProductDetails/@item.Id" class="product-image">
                                <img src="@item.ImageUrl" alt="@item.ProductName" />
                            </a>

                            @if (Context.Session.GetString("UserName") == null)
                            {
                                <button type="button"
                                        class="favorite-heart"
                                        onclick="loginAlert()"
                                        title="Favorilere ekle">
                                    ♥
                                </button>
                            }
                            else
                            {
                                <a href="/Favorite/AddToFavorite/@item.Id"
                                   class="favorite-heart"
                                   title="Favorilere ekle">
                                    ♥
                                </a>
                            }
                        </div>

                        <div class="product-body">
                            <div class="product-category">
                                @(item.Category != null ? item.Category.CategoryName : "Kategori Yok")
                            </div>

                            <a href="/Product/ProductDetails/@item.Id" class="product-title">
                                @item.ProductName
                            </a>

                            <div class="product-brand">@item.Brand</div>

                            @{
                                var averageRatings = ViewBag.ProductAverageRatings as System.Collections.Generic.Dictionary<int, double>;
                                var ratingCounts = ViewBag.ProductRatingCounts as System.Collections.Generic.Dictionary<int, int>;

                                double averageRating = 0;
                                int ratingCount = 0;

                                if (averageRatings != null)
                                {
                                    averageRatings.TryGetValue(item.Id, out averageRating);
                                }

                                if (ratingCounts != null)
                                {
                                    ratingCounts.TryGetValue(item.Id, out ratingCount);
                                }

                                var roundedRating = (int)Math.Round(averageRating);
                            }

                            <div class="product-rating">
                                <span class="rating-number">@averageRating.ToString("0.0")</span>

                                <span class="rating-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= roundedRating)
                                        {
                                            <span class="star filled">★</span>
                                        }
                                        else
                                        {
                                            <span class="star">★</span>
                                        }
                                    }
                                </span>

                                <span class="rating-count">(@ratingCount)</span>
                            </div>

                            <div class="product-location">
                                @item.City / @item.District
                            </div>

                            <div class="product-prices">
                                <div>
                                    <span>Günlük kira</span>
                                    <strong>@item.DailPrice ₺</strong>
                                </div>
                                <div>
                                    <span>Satış</span>
                                    <strong>@item.SalePrice ₺</strong>
                                </div>
                            </div>

                            <div class="product-meta">
                                @if (item.StockCount <= 0)
                                {
                                    <span class="stock-badge danger">Tükendi</span>
                                }
                                else
                                {
                                    <span class="stock-badge">@item.StockCount adet</span>
                                }

                                @if (item.IsRentable)
                                {
                                    <span class="rent-badge">Kiralanabilir</span>
                                }
                                else
                                {
                                    <span class="rent-badge danger">Kiralanamaz</span>
                                }
                            </div>

                            <div class="product-actions">
                                <a href="/Product/ProductDetails/@item.Id" class="btn btn-info btn-sm">Detay</a>

                                @if (Context.Session.GetString("UserName") == null)
                                {
                                    <button type="button" class="btn btn-success btn-sm" onclick="loginAlert()">Sepet</button>
                                    
                                }
                                else
                                {
                                    <a href="/Cart/AddToCart/@item.Id" class="btn btn-success btn-sm">Sepet</a>
                                    
                                }

                                @if (Context.Session.GetString("UserRole") == "Admin")
                                {
                                    <a href="/Product/UpdateProduct/@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                                    <a href="/Product/DeleteProduct/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <script>
                            function loginAlert() {
                                Swal.fire({
                                    icon: 'warning',
                                    title: 'Giriş yapmanız gerekiyor',
                                    text: 'Bu işlemi yapmak için giriş yapmalısınız.',
                                    showCancelButton: true,
                                    confirmButtonText: 'Giriş Yap',
                                    cancelButtonText: 'Vazgeç'
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        window.location.href = '/Login/Index';
                                    }
                                });
                            }
            </script>

        </div>
    </div>
</div>
