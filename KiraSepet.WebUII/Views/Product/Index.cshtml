@using Microsoft.AspNetCore.Http
@{
    var isAdmin = Context.Session.GetString("UserRole") == "Admin";
}
<div class="container-fluid px-4">

    <div class="row mb-4">

        <div class="col-12">
            
            <div class="d-flex justify-content-between align-items-center mb-4">

                <h2 class="fw-bold text-primary">
                    Ürün Listesi
                </h2>

                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a href="/Product/AddProduct" class="btn btn-primary">Ürün Ekle</a>
                }

            </div>

            
            <div class="p-5 mb-4 rounded-4 shadow-sm text-center text-white"
                 style="background: linear-gradient(135deg, #0d6efd, #6610f2);">

                <h1 class="display-3 fw-bold">KiraSat</h1>

                <p class="fs-4 mt-3">
                    Satın al, ihtiyacın kadar kirala.
                </p>

                <p class="mb-0 opacity-75">
                    Ürünleri keşfet, favorilerine ekle, sepete at veya kirala.
                </p>
            </div>

                
            

        

            <form method="get" class="d-flex gap-2 mb-4">

                <input type="text"
                       name="p"
                       class="form-control"
                       placeholder="Ürün ara..." />

                <input type="text"
                       name="city"
                       class="form-control"
                       placeholder="Şehir ara..." />

                <input type="text"
                       name="district"
                       class="form-control"
                       placeholder="İlçe ara..." />

                <button class="btn btn-primary">
                    Ara
                </button>

            </form>


            <div class="table-responsive w-100">

                <table class="table table-hover table-striped table-bordered shadow-sm align-middle w-100">

            <tr class="table-dark">
                
                <th>ID</th>
                <th>Görsel</th>
                <th>Ürün Adı</th>
                <th>Marka</th>
                <th>Fiyat</th>
                <th>Konum</th>
                <th>Kategori</th>
                <th>Stok</th>
                <th>Kiralanabilir</th>
                <th>İşlem</th>
            
            </tr>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Id</td>

                            <a href="/Product/ProductDetails/@item.Id">
                                <img src="@item.ImageUrl" width="80" height="80"
                                     style="object-fit:cover; border-radius:10px;" />
                            </a>

                   <td>
                   <a href="/Product/ProductDetails/@item.Id" class="text-decoration-none fw-bold text-dark">
                   @item.ProductName
                   </a>
                   </td>

                    <td>@item.Brand</td>

                    <td>
                        <div>
                            <strong>Günlük Kira:</strong> @item.DailPrice ₺
                        </div>

                        <div>
                            <strong>Satış:</strong> @item.SalePrice ₺
                        </div>
                    </td>

                            <td>
                                <span class="badge bg-info text-dark px-3 py-2">
                                    📍 @item.City / @item.District
                                </span>
                            </td>

                            <td>
                                @(item.Category != null
                                ? item.Category.CategoryName
                                : "Kategori Yok")
                            </td>

                           
                    <td>
                        @if (item.StockCount <= 0)
                        {
                            <span class="badge bg-danger">Tükendi</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@item.StockCount adet</span>
                        }

                    </td>
                    <td>
                        @if (item.IsRentable)
                        {
                            <span class="badge bg-success">Evet</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Hayır</span>
                        }
                    </td>

                            <td>
                                @if (Context.Session.GetString("UserRole") == "Admin")
                                {
                                    <a href="/Product/UpdateProduct/@item.Id" class="btn btn-warning btn-sm">✏️ Güncelle</a>
                                    <a href="/Product/DeleteProduct/@item.Id" class="btn btn-danger btn-sm">🗑️ Sil</a>
                                }

                                <a href="/Product/ProductDetails/@item.Id" class="btn btn-info btn-sm">🔍 Detay</a>
                                @if (Context.Session.GetString("UserName") == null)
                                {
                                    <button type="button" class="btn btn-success btn-sm" onclick="loginAlert()">
                                        🛒 Sepet
                                    </button>
                                }
                                else
                                {
                                    <a href="/Cart/AddToCart/@item.Id" class="btn btn-success btn-sm">
                                        🛒 Sepet
                                    </a>
                                }
                                @if (Context.Session.GetString("UserName") == null)
                                {
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="loginAlert()">
                                        💖 Favori
                                    </button>
                                }
                                else
                                {
                                    <a href="/Favorite/AddToFavorite/@item.Id" class="btn btn-outline-danger btn-sm">
                                        💖 Favori
                                    </a>
                                }
                    </td>

                            <style>
                                                        .action-buttons {
                                                            display: grid;
                                                            grid-template-columns: repeat(2, 1fr);
                                                            gap: 6px;
                                                            min-width: 190px;
                                                        }

                                                            .action-buttons .btn {
                                                                border-radius: 10px;
                                                                font-size: 13px;
                                                                font-weight: 600;
                                                                padding: 7px 8px;
                                                                white-space: nowrap;
                                                                box-shadow: 0 2px 5px rgba(0,0,0,0.10);
                                                                transition: 0.2s;
                                                            }

                                                                .action-buttons .btn:hover {
                                                                    transform: scale(1.03);
                                                                    opacity: 0.92;
                                                                }
                            </style>

                            <style>
                                                        .hero-text {
                                                            text-align: center;
                                                            margin-bottom: 35px;
                                                            margin-top: 20px;
                                                        }

                                                            .hero-text h1 {
                                                                font-size: 72px;
                                                                font-weight: 800;
                                                                background: linear-gradient(90deg,#0d6efd,#00c6ff);
                                                                -webkit-background-clip: text;
                                                                -webkit-text-fill-color: transparent;
                                                                letter-spacing: 2px;
                                                                text-shadow: 0 4px 15px rgba(0,0,0,0.10);
                                                                margin-bottom: 10px;
                                                            }

                                                            .hero-text p {
                                                                font-size: 22px;
                                                                color: #666;
                                                                font-weight: 500;
                                                            }
                            </style>

                </tr>


                        <script>
                                                function loginAlert() {
                                                    Swal.fire({
                                                        icon: 'warning',
                                                        title: 'Giriş yapmanız gerekiyor',
                                                        text: 'Bu işlemi yapmak için giriş yapmalısınız.',
                                                        showCancelButton: true,
                                                        confirmButtonText: 'Giriş Yap',
                                                        cancelButtonText: 'Vazgeç'
                                                    }).then((result) => {
                                                        if (result.isConfirmed) {
                                                            window.location.href = '/Login/Index';
                                                        }
                                                    });
                                                }
                        </script>

                                                              
            }