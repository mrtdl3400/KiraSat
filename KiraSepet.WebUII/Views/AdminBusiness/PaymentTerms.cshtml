@model KiraSepet.EntityLayer.LegalText
@using System.Net

@{
    ViewData["Title"] = "Ödeme ve Kiralama Şartları";
    var content = Model.Content ?? "";
    var editorHtml = content.Contains("<")
        ? content
        : string.Join("", content
            .Replace("\r\n", "\n")
            .Split("\n\n", StringSplitOptions.RemoveEmptyEntries)
            .Select(x => $"<p>{WebUtility.HtmlEncode(x.Trim()).Replace("\n", "<br />")}</p>"));
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Ödeme ve Kiralama Şartları</h1>
            <p class="text-muted mb-0">Ödeme sayfasında kullanıcının okuyup onayladığı metni buradan düzenleyebilirsiniz.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Admin Paneline Dön
        </a>
    </div>

    @if (TempData["BusinessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["BusinessMessage"]
        </div>
    }

    @if (TempData["BusinessError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["BusinessError"]
        </div>
    }

    <form asp-action="PaymentTerms" method="post" class="card shadow-sm p-4" id="paymentTermsForm">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Key" value="PaymentTerms" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Başlık</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Content" class="form-label">Metin</label>

            <div class="legal-editor-toolbar">
                <button type="button" id="toggleEditButton" class="btn btn-sm btn-primary">Düzenle</button>
                <span id="editorStatus" class="editor-status">Düzenleme açık</span>

                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="bold" title="Kalın">B</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="fontName" data-value="Arial" title="Tok yazı">Tok</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="italic" title="Eğik"><em>I</em></button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="underline" title="Altı çizili"><u>U</u></button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="strikeThrough" title="Üstü çizili"><s>S</s></button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="removeFormat" title="Biçimi temizle">Normal</button>

                <select id="blockFormatSelect" class="form-select form-select-sm legal-toolbar-select" title="Metin tipi">
                    <option value="">Metin tipi</option>
                    <option value="P">Paragraf</option>
                    <option value="H3">Başlık</option>
                    <option value="H4">Alt başlık</option>
                </select>

                <select id="fontSizeSelect" class="form-select form-select-sm legal-toolbar-select" title="Yazı boyutu">
                    <option value="">Boyut</option>
                    <option value="2">Küçük</option>
                    <option value="3">Normal</option>
                    <option value="4">Büyük</option>
                    <option value="5">Çok Büyük</option>
                </select>

                <select id="fontWeightSelect" class="form-select form-select-sm legal-toolbar-select" title="Yazı kalınlığı">
                    <option value="">Kalınlık</option>
                    <option value="500">Orta</option>
                    <option value="600">Koyu</option>
                    <option value="700">Kalın</option>
                    <option value="800">Çok kalın</option>
                </select>

                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="insertUnorderedList" title="Madde listesi">• Liste</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="insertOrderedList" title="Numaralı liste">1. Liste</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="justifyLeft" title="Sola hizala">Sol</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="justifyCenter" title="Ortala">Orta</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-command="justifyRight" title="Sağa hizala">Sağ</button>

                <label class="legal-color-picker" title="Yazı rengi">
                    Yazı
                    <input type="color" id="fontColorInput" value="#0f172a" />
                </label>

                <label class="legal-color-picker" title="Arka plan rengi">
                    Zemin
                    <input type="color" id="backColorInput" value="#fff7ed" />
                </label>
            </div>

            <div id="legalEditor" class="legal-editor" contenteditable="true">@Html.Raw(editorHtml)</div>
            <textarea asp-for="Content" id="Content" class="d-none"></textarea>
            <div class="form-text">
                ChatGPT'den gelen **Başlık** biçimini direkt yapıştırabilirsiniz. Sistem başlıkları otomatik kalın ve güçlü gösterir.
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary">
                Metni Kaydet
            </button>
        </div>
    </form>
</div>

<script>
    const legalEditor = document.getElementById('legalEditor');
    const contentInput = document.getElementById('Content');
    const paymentTermsForm = document.getElementById('paymentTermsForm');
    const fontSizeSelect = document.getElementById('fontSizeSelect');
    const fontWeightSelect = document.getElementById('fontWeightSelect');
    const blockFormatSelect = document.getElementById('blockFormatSelect');
    const fontColorInput = document.getElementById('fontColorInput');
    const backColorInput = document.getElementById('backColorInput');
    const toggleEditButton = document.getElementById('toggleEditButton');
    const editorStatus = document.getElementById('editorStatus');
    let savedSelection = null;
    let isEditing = true;

    function saveSelection() {
        const selection = window.getSelection();
        if (selection && selection.rangeCount > 0 && legalEditor.contains(selection.anchorNode)) {
            savedSelection = selection.getRangeAt(0);
        }
    }

    function restoreSelection() {
        ensureEditing();
        legalEditor.focus();
        const selection = window.getSelection();
        if (savedSelection && selection) {
            selection.removeAllRanges();
            selection.addRange(savedSelection);
        }
    }

    function runCommand(command, value = null) {
        restoreSelection();
        document.execCommand(command, false, value);
        saveSelection();
    }

    function ensureEditing() {
        if (isEditing) {
            return;
        }

        isEditing = true;
        legalEditor.setAttribute('contenteditable', 'true');
        legalEditor.classList.remove('is-disabled');
        editorStatus.textContent = 'Düzenleme açık';
        toggleEditButton.textContent = 'Düzenle';
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function convertPlainTextToRichHtml(text) {
        const paragraphs = text
            .replace(/\r\n/g, '\n')
            .split(/\n{2,}/)
            .map(function (paragraph) {
                return paragraph.trim();
            })
            .filter(Boolean);

        return paragraphs.map(function (paragraph) {
            const strongHeadingMatch = paragraph.match(/^\*\*(.+?)\*\*$/);

            if (strongHeadingMatch) {
                return '<h3><strong>' + escapeHtml(strongHeadingMatch[1]) + '</strong></h3>';
            }

            let html = escapeHtml(paragraph).replace(/\n/g, '<br>');
            html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

            return '<p>' + html + '</p>';
        }).join('');
    }

    function applyInlineStyle(styleText) {
        restoreSelection();
        const selection = window.getSelection();
        if (!selection || selection.rangeCount === 0) {
            return;
        }

        const range = selection.getRangeAt(0);

        if (range.collapsed) {
            document.execCommand('insertHTML', false, '<span style="' + styleText + '">&#8203;</span>');
        } else {
            const selectedHtml = range.cloneContents();
            const wrapper = document.createElement('span');
            wrapper.setAttribute('style', styleText);
            wrapper.appendChild(selectedHtml);
            range.deleteContents();
            range.insertNode(wrapper);
        }

        saveSelection();
    }

    legalEditor.addEventListener('keyup', saveSelection);
    legalEditor.addEventListener('mouseup', saveSelection);
    legalEditor.addEventListener('focus', saveSelection);
    legalEditor.addEventListener('input', saveSelection);

    legalEditor.addEventListener('paste', function (event) {
        event.preventDefault();
        const text = (event.clipboardData || window.clipboardData).getData('text/plain');
        const html = convertPlainTextToRichHtml(text);

        if (html) {
            document.execCommand('insertHTML', false, html);
        } else {
            document.execCommand('insertText', false, text);
        }

        saveSelection();
    });

    document.querySelectorAll('[data-command]').forEach(function (button) {
        button.addEventListener('mousedown', function (event) {
            event.preventDefault();
        });

        button.addEventListener('click', function () {
            runCommand(button.dataset.command, button.dataset.value || null);
        });
    });

    blockFormatSelect.addEventListener('focus', function () {
        ensureEditing();
    });

    blockFormatSelect.addEventListener('change', function () {
        if (!this.value) {
            return;
        }

        runCommand('formatBlock', this.value);
        this.value = '';
    });

    fontSizeSelect.addEventListener('focus', function () {
        ensureEditing();
    });

    fontSizeSelect.addEventListener('change', function () {
        if (!this.value) {
            return;
        }

        runCommand('fontSize', this.value);
        this.value = '';
    });

    fontWeightSelect.addEventListener('focus', function () {
        ensureEditing();
    });

    fontWeightSelect.addEventListener('change', function () {
        if (!this.value) {
            return;
        }

        applyInlineStyle('font-weight: ' + this.value + ';');
        this.value = '';
    });

    fontColorInput.addEventListener('focus', function () {
        ensureEditing();
    });

    fontColorInput.addEventListener('input', function () {
        runCommand('foreColor', this.value);
    });

    backColorInput.addEventListener('focus', function () {
        ensureEditing();
    });

    backColorInput.addEventListener('input', function () {
        runCommand('hiliteColor', this.value);
    });

    toggleEditButton.addEventListener('click', function () {
        isEditing = !isEditing;
        legalEditor.setAttribute('contenteditable', isEditing ? 'true' : 'false');
        legalEditor.classList.toggle('is-disabled', !isEditing);
        editorStatus.textContent = isEditing ? 'Düzenleme açık' : 'Düzenleme kapalı';
        toggleEditButton.textContent = isEditing ? 'Düzenle' : 'Düzenlemeyi Aç';

        if (isEditing) {
            legalEditor.focus();
            saveSelection();
        }
    });

    paymentTermsForm.addEventListener('submit', function () {
        contentInput.value = legalEditor.innerHTML.trim();
    });
</script>

<style>
    .legal-editor-toolbar {
        align-items: center;
        background: #f8fafc;
        border: 1px solid #dbe4ef;
        border-bottom: 0;
        border-radius: 10px 10px 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 10px;
    }

    .editor-status {
        background: #dcfce7;
        border: 1px solid #86efac;
        border-radius: 999px;
        color: #166534;
        font-size: 12px;
        font-weight: 700;
        padding: 5px 9px;
    }

    .legal-toolbar-select {
        max-width: 125px;
    }

    .legal-color-picker {
        align-items: center;
        border: 1px solid #ced4da;
        border-radius: 6px;
        color: #475569;
        display: inline-flex;
        font-size: 13px;
        gap: 8px;
        height: 31px;
        margin: 0;
        padding: 0 8px;
    }

    .legal-color-picker input {
        border: 0;
        height: 22px;
        padding: 0;
        width: 28px;
    }

    .legal-editor {
        border: 1px solid #ced4da;
        border-radius: 0 0 10px 10px;
        color: #0f172a;
        font-weight: 500;
        line-height: 1.6;
        min-height: 360px;
        outline: none;
        overflow-y: auto;
        padding: 14px;
    }

    .legal-editor h3,
    .legal-editor h4 {
        color: #0f172a;
        font-weight: 800;
    }

    .legal-editor.is-disabled {
        background: #f8fafc;
        color: #64748b;
    }

    .legal-editor:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 .2rem rgba(13, 110, 253, .15);
    }

    .legal-editor p,
    .legal-editor ul,
    .legal-editor ol {
        margin-bottom: 12px;
    }
</style>
