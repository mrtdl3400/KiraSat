@using KiraSepet.EntityLayer
@model List<RentalMessage>

@{
    var product = ViewBag.Product as Product;
    var conversation = ViewBag.Conversation as RentalConversation;
    var currentUserId = ViewBag.CurrentUserId == null ? 0 : (int)ViewBag.CurrentUserId;
    var businessName = ViewBag.BusinessName as string ?? "İşletme bilgisi bulunamadı";
    var counterpartName = ViewBag.CounterpartName as string ?? "Bilinmiyor";
    var counterpartEmail = ViewBag.CounterpartEmail as string ?? "E-posta bulunamadı";

    var alternativeProducts = ViewBag.AlternativeProducts as List<Product> ?? new List<Product>();
    var isOwner = ViewBag.IsOwner == true;
    var messageProductCards = ViewBag.MessageProductCards as Dictionary<int, Product>
    ?? new Dictionary<int, Product>();


    ViewData["Title"] = "İlan Sahibiyle Mesajlaş";
}

<div class="conversation-page">
    <div class="conversation-header">
        <div>
            <span class="conversation-label">İLAN HAKKINDA SOHBET</span>
            <h2>@(product?.ProductName ?? "Ürün")</h2>
            <p>İlan sahibiyle güvenli şekilde mesajlaşabilirsiniz.</p>

            <div class="conversation-contact-info">
                <div>
                    <span>İşletme</span>
                    <strong>@businessName</strong>
                </div>

                <div>
                    <span>Görüşülen kişi</span>
                    <strong>@counterpartName</strong>
                    <a href="mailto:@counterpartEmail">@counterpartEmail</a>
                </div>
            </div>
        </div>

        <a href="/Product/ProductDetails?id=@product?.Id" class="conversation-back">
            ← Ürüne dön
        </a>
    </div>

    <div class="chat-window">
        @if (!Model.Any())
        {
            <div class="chat-empty">
                <div class="chat-empty-icon">✉</div>
                <h5>Sohbeti başlatın</h5>
                <p>İlan hakkında merak ettiğiniz şeyi yazabilirsiniz.</p>
            </div>
        }
        else
        {
            @foreach (var message in Model)
            {
                var isMine = message.SenderUserId == currentUserId;

                <div class="chat-row @(isMine ? "my-message" : "other-message")">
                    <div class="chat-bubble">
                        <p>@message.Text</p>

                        @{
                            var productMatch = System.Text.RegularExpressions.Regex.Match(message.Text, @"ProductDetails\?id=(\d+)");
                            Product? offeredProduct = null;

                            if (productMatch.Success)
                            {
                                var offeredProductId = int.Parse(productMatch.Groups[1].Value);
                                messageProductCards.TryGetValue(offeredProductId, out offeredProduct);
                            }
                        }

                        @if (offeredProduct != null)
                        {
                            <a class="message-product-card"
                               href="/Product/ProductDetails?id=@offeredProduct.Id">
                                @if (!string.IsNullOrWhiteSpace(offeredProduct.ImageUrl))
                                {
                                    <img src="@offeredProduct.ImageUrl" alt="@offeredProduct.ProductName" />
                                }
                                else
                                {
                                    <div class="message-product-placeholder">Ürün</div>
                                }

                                <div>
                                    <strong>@offeredProduct.ProductName</strong>
                                    <span>Ürüne git →</span>
                                </div>
                            </a>
                        }
                        <small>
                            @message.SentAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            @if (isMine)
                            {
                                <span class="message-status">@(message.IsRead ? "✓✓" : "✓")</span>
                            }
                        </small>
                    </div>
                </div>
            }
        }
    </div>

    @if (isOwner && alternativeProducts.Any())
    {
        <div class="alternative-offer-box">
            <div>
                <strong>Alternatif ürün öner</strong>
                <p>Bu konuşmadaki kullanıcıya başka bir ürününüzü teklif edebilirsiniz.</p>
            </div>

            <div class="alternative-offer-controls">
                <select id="alternativeProductSelect" class="form-select">
                    <option value="">Ürün seç</option>
                    @foreach (var alternativeProduct in alternativeProducts)
                    {
                        <option value="@alternativeProduct.Id"
                                data-name="@alternativeProduct.ProductName">
                            @alternativeProduct.ProductName
                        </option>
                    }
                </select>

                <button type="button" id="createAlternativeMessage">
                    Hazır mesaj oluştur
                </button>
            </div>
        </div>
    }

    <form asp-action="Send" method="post" class="chat-compose">
        @Html.AntiForgeryToken()

        <input type="hidden" name="conversationId" value="@conversation?.Id" />

        <textarea id="messageText"
                  name="text"
                  class="form-control"
                  rows="3"
                  placeholder="Mesajınızı yazın..."
                  required></textarea>

        <button type="submit">Gönder →</button>
    </form>

    <script>
            const alternativeSelect = document.getElementById("alternativeProductSelect");
            const createAlternativeMessageButton = document.getElementById("createAlternativeMessage");
            const messageText = document.getElementById("messageText");

            if (alternativeSelect && createAlternativeMessageButton && messageText) {
                createAlternativeMessageButton.addEventListener("click", function () {
                    const selectedOption = alternativeSelect.options[alternativeSelect.selectedIndex];

                    if (!selectedOption || !selectedOption.value) {
                        return;
                    }

                    const productName = selectedOption.dataset.name;
                    const productUrl = `${window.location.origin}/Product/ProductDetails?id=${selectedOption.value}`;

                    messageText.value =
                        `Merhaba, bu üründe geçici bir sorun oluştu. Dilerseniz bunun yerine şu ürünü önerebiliriz:\n\n${productName}\n${productUrl}`;

                    messageText.focus();
                });
            }
    </script>

</div>

<style>

    .message-product-card {
        align-items: center;
        background: rgba(255, 255, 255, .18);
        border: 1px solid rgba(255, 255, 255, .35);
        border-radius: 14px;
        color: inherit;
        display: flex;
        gap: 12px;
        margin-top: 10px;
        padding: 10px;
        text-decoration: none;
    }

    .other-message .message-product-card {
        background: #f8fafc;
        border-color: #e2e8f0;
        color: #0f172a;
    }

    .message-product-card img,
    .message-product-placeholder {
        border-radius: 10px;
        height: 58px;
        object-fit: cover;
        width: 72px;
    }

    .message-product-placeholder {
        align-items: center;
        background: #e2e8f0;
        color: #64748b;
        display: flex;
        font-size: 12px;
        font-weight: 800;
        justify-content: center;
    }

    .message-product-card strong {
        display: block;
        font-weight: 900;
        margin-bottom: 4px;
    }

    .message-product-card span {
        font-size: 12px;
        font-weight: 800;
        opacity: .9;
    }

    .alternative-offer-box {
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-bottom: 0;
        padding: 16px;
    }

        .alternative-offer-box strong {
            color: #9a3412;
            display: block;
            font-weight: 900;
            margin-bottom: 4px;
        }

        .alternative-offer-box p {
            color: #7c2d12;
            margin: 0 0 12px;
        }

    .alternative-offer-controls {
        display: flex;
        gap: 12px;
    }

        .alternative-offer-controls select {
            border-radius: 12px;
        }

        .alternative-offer-controls button {
            background: #f97316;
            border: 0;
            border-radius: 12px;
            color: white;
            font-weight: 800;
            padding: 9px 14px;
            white-space: nowrap;
        }

    .conversation-page {
        max-width: 900px;
        margin: 48px auto;
        padding: 0 20px;
    }

    .conversation-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 20px;
        margin-bottom: 20px;
    }

    .conversation-label {
        color: #f97316;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .conversation-header h2 {
        color: #0f172a;
        font-weight: 900;
        margin: 5px 0 6px;
    }

    .conversation-header p {
        color: #64748b;
        margin: 0;
    }

    .conversation-contact-info {
        display: flex;
        gap: 12px;
        margin-top: 16px;
    }

        .conversation-contact-info > div {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            min-width: 180px;
            padding: 10px 12px;
        }

        .conversation-contact-info span {
            color: #64748b;
            display: block;
            font-size: 11px;
            font-weight: 800;
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        .conversation-contact-info strong {
            color: #1e293b;
            display: block;
            font-size: 14px;
        }

        .conversation-contact-info a {
            color: #2563eb;
            display: block;
            font-size: 12px;
            margin-top: 3px;
            text-decoration: none;
        }

    @@media (max-width: 576px) {
        .conversation-contact-info {
            flex-direction: column;
        }
    }

    .conversation-back {
        background: #f1f5f9;
        border-radius: 12px;
        color: #334155;
        font-weight: 800;
        padding: 10px 14px;
        text-decoration: none;
        white-space: nowrap;
    }

    .chat-window {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 22px 22px 0 0;
        min-height: 380px;
        padding: 24px;
    }

    .chat-row {
        display: flex;
        margin-bottom: 14px;
    }

    .my-message {
        justify-content: flex-end;
    }

    .other-message {
        justify-content: flex-start;
    }

    .chat-bubble {
        border-radius: 18px;
        max-width: 75%;
        padding: 12px 16px;
    }

    .my-message .chat-bubble {
        background: #f97316;
        border-bottom-right-radius: 4px;
        color: white;
    }

    .other-message .chat-bubble {
        background: white;
        border: 1px solid #e2e8f0;
        border-bottom-left-radius: 4px;
        color: #1e293b;
    }

    .chat-bubble p {
        margin: 0 0 5px;
        white-space: pre-wrap;
    }

    .chat-bubble small {
        font-size: 11px;
        opacity: .78;
    }

    .message-status {
        font-size: 14px;
        font-weight: 900;
        letter-spacing: -3px;
        margin-left: 5px;
    }

    .chat-empty {
        color: #64748b;
        padding: 90px 20px;
        text-align: center;
    }

    .chat-empty-icon {
        align-items: center;
        background: #e0e7ff;
        border-radius: 50%;
        color: #4f46e5;
        display: inline-flex;
        font-size: 25px;
        height: 58px;
        justify-content: center;
        margin-bottom: 12px;
        width: 58px;
    }

    .chat-empty h5 {
        color: #1e293b;
        font-weight: 800;
    }

    .chat-compose {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0 0 22px 22px;
        display: flex;
        gap: 12px;
        padding: 16px;
    }

        .chat-compose textarea {
            border-radius: 14px;
            resize: none;
        }

        .chat-compose button {
            align-self: stretch;
            background: #0f172a;
            border: 0;
            border-radius: 14px;
            color: white;
            font-weight: 800;
            min-width: 120px;
            padding: 0 20px;
        }

    @@media (max-width: 576px) {
        .conversation-header,
        .chat-compose {
            flex-direction: column;
        }

            .conversation-back,
            .chat-compose button {
                width: 100%;
            }

            .chat-compose button {
                min-height: 48px;
            }

        .chat-bubble {
            max-width: 90%;
        }
    }

    @@media (max-width: 576px) {
        .alternative-offer-controls {
            flex-direction: column;
        }

            .alternative-offer-controls button {
                width: 100%;
            }
    }

</style>
