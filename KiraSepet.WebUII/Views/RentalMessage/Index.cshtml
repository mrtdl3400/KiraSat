@using KiraSepet.EntityLayer
@model List<RentalConversation>

@{
    var products = ViewBag.Products as Dictionary<int, string>
        ?? new Dictionary<int, string>();
    var latestMessages = ViewBag.LatestMessages as Dictionary<int, string>
        ?? new Dictionary<int, string>();
    var unreadConversationIds = ViewBag.UnreadConversationIds as HashSet<int>
        ?? new HashSet<int>();

    var counterpartNames = ViewBag.CounterpartNames as Dictionary<int, string>
?? new Dictionary<int, string>();

    var counterpartEmails = ViewBag.CounterpartEmails as Dictionary<int, string>
        ?? new Dictionary<int, string>();

    var businessNames = ViewBag.BusinessNames as Dictionary<int, string>
        ?? new Dictionary<int, string>();

    var productBusinessIds = ViewBag.ProductBusinessIds as Dictionary<int, int?>
        ?? new Dictionary<int, int?>();

    var currentUserId = ViewBag.CurrentUserId == null
        ? 0
        : (int)ViewBag.CurrentUserId;

    ViewData["Title"] = "İlan Mesajlarım";
}

<div class="container py-5" style="max-width: 900px;">
    <p class="text-uppercase text-primary fw-bold mb-1" style="font-size: 12px;">
        İLAN MESAJLARI
    </p>

    <h2 class="fw-bold">Sohbetlerim</h2>
    <p class="text-muted mb-4">
        Kiracı veya ilan sahibi olduğunuz konuşmalar.
    </p>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5">
            <div style="font-size: 42px;">✉</div>
            <h5 class="mt-3 fw-bold">Henüz ilan sohbetiniz yok</h5>
            <p class="text-muted mb-0">
                Bir ürünün detayından işletme sahibine mesaj gönderebilirsiniz.
            </p>
        </div>
    }
    else
    {
        <div class="rental-conversation-list">
            @foreach (var conversation in Model)
            {
                var productName = products.ContainsKey(conversation.ProductId)
                    ? products[conversation.ProductId]
                    : "Ürün bulunamadı";

                var productInitial = string.IsNullOrWhiteSpace(productName)
                    ? "Ü"
                    : productName.Substring(0, 1).ToUpper();

                var hasUnread = unreadConversationIds.Contains(conversation.Id);

                var isOwner = conversation.OwnerUserId == currentUserId;

                var counterpartId = isOwner
                ? conversation.TenantUserId
                : conversation.OwnerUserId;

                var counterpartName = counterpartNames.ContainsKey(counterpartId)
                    ? counterpartNames[counterpartId]
                    : "Bilinmiyor";

                var counterpartEmail = counterpartEmails.ContainsKey(counterpartId)
                    ? counterpartEmails[counterpartId]
                    : "E-posta bulunamadı";

                var businessId = productBusinessIds.ContainsKey(conversation.ProductId)
                    ? productBusinessIds[conversation.ProductId]
                    : null;

                var businessName = businessId.HasValue && businessNames.ContainsKey(businessId.Value)
                    ? businessNames[businessId.Value]
                    : "İşletme bilgisi bulunamadı";
                var latestMessage = latestMessages.ContainsKey(conversation.Id)
                    ? latestMessages[conversation.Id]
                    : "Henüz mesaj yok.";

                if (latestMessage.Length > 90)
                {
                    latestMessage = latestMessage.Substring(0, 90) + "...";
                }

                <a href="/RentalMessage/Conversation?id=@conversation.Id"
                   class="rental-conversation-card @(hasUnread ? "has-unread" : "")">
                    <div class="conversation-avatar">@productInitial</div>

                    <div class="conversation-main">
                        <div class="conversation-title-row">
                            <h5>@productName</h5>
                            <span class="conversation-role-chip">@(isOwner ? "Kiracı" : "İşletme")</span>
                        </div>

                        <p class="conversation-meta">
                            @businessName <span>•</span> @counterpartName
                        </p>

                        <p class="conversation-preview">@latestMessage</p>
                        <small>@counterpartEmail</small>
                    </div>

                    <div class="conversation-side">
                        @if (hasUnread)
                        {
                            <span class="unread-message-label">Yeni mesaj</span>
                        }
                        <small>@conversation.LastMessageAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                </a>
            }
        </div>
    }
</div>

<style>
    .rental-conversation-list {
        display: grid;
        gap: 16px;
    }

    .rental-conversation-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .05);
        padding: 22px;
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .rental-conversation-card:hover {
        box-shadow: 0 14px 30px rgba(15, 23, 42, .10);
        transform: translateY(-2px);
    }

    .conversation-card-top {
        align-items: start;
        display: flex;
        gap: 16px;
        justify-content: space-between;
    }

    .conversation-role-chip {
        background: #fff7ed;
        border-radius: 999px;
        color: #c2410c;
        display: inline-block;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: .7px;
        padding: 5px 9px;
    }

    .conversation-card-top h5 {
        color: #0f172a;
        font-size: 20px;
        font-weight: 900;
        margin: 10px 0 0;
    }

    .open-conversation-btn {
        background: #0f172a;
        border-radius: 10px;
        color: #fff;
        font-size: 13px;
        font-weight: 800;
        padding: 10px 13px;
        text-decoration: none;
        white-space: nowrap;
    }

    .open-conversation-btn span {
        margin-left: 4px;
    }

    .conversation-info-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        margin: 20px 0 14px;
    }

    .conversation-info-item {
        background: #f8fafc;
        border-radius: 12px;
        padding: 12px 14px;
    }

    .conversation-info-item span,
    .conversation-preview span {
        color: #64748b;
        display: block;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .4px;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .conversation-info-item strong {
        color: #1e293b;
        display: block;
        font-size: 14px;
    }

    .conversation-info-item small {
        color: #64748b;
        display: block;
        margin-top: 4px;
        overflow-wrap: anywhere;
    }

    .conversation-preview {
        border-left: 3px solid #f97316;
        padding: 4px 0 4px 13px;
    }

    .conversation-preview p {
        color: #334155;
        margin: 0;
    }

    .conversation-card-footer {
        border-top: 1px solid #eef2f7;
        color: #94a3b8;
        font-size: 12px;
        margin-top: 16px;
        padding-top: 14px;
    }

    @@media (max-width: 576px) {
        .conversation-card-top,
        .conversation-info-grid {
            grid-template-columns: 1fr;
        }

        .conversation-card-top {
            display: grid;
        }

        .open-conversation-btn {
            text-align: center;
        }
    }

    /* Compact inbox layout */
    .rental-conversation-card {
        align-items: center;
        background: #fff;
        border: 1px solid #e6ebf2;
        border-radius: 16px;
        box-shadow: none;
        display: grid;
        gap: 14px;
        grid-template-columns: 46px minmax(0, 1fr) auto;
        padding: 16px 18px;
        text-decoration: none;
    }

    .rental-conversation-card:hover {
        box-shadow: 0 8px 20px rgba(15, 23, 42, .06);
        transform: none;
    }

    .rental-conversation-card.has-unread {
        background: #fffdf7;
        border-color: #fdba74;
    }

    .rental-conversation-card.has-unread .conversation-title-row h5,
    .rental-conversation-card.has-unread .conversation-main .conversation-preview {
        color: #0f172a;
        font-weight: 800;
    }

    .conversation-avatar {
        align-items: center;
        background: linear-gradient(135deg, #fff7ed, #ffedd5);
        border-radius: 14px;
        color: #c2410c;
        display: flex;
        font-size: 18px;
        font-weight: 900;
        height: 46px;
        justify-content: center;
        width: 46px;
    }

    .conversation-main {
        min-width: 0;
    }

    .conversation-title-row {
        align-items: center;
        display: flex;
        gap: 8px;
        min-width: 0;
    }

    .conversation-title-row h5 {
        color: #172033;
        font-size: 16px;
        font-weight: 800;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .conversation-role-chip {
        background: #f1f5f9;
        color: #64748b;
        flex: 0 0 auto;
        font-size: 10px;
        letter-spacing: 0;
        padding: 3px 7px;
    }

    .conversation-meta,
    .conversation-main .conversation-preview,
    .conversation-main small {
        margin: 4px 0 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .conversation-meta {
        color: #475569;
        font-size: 13px;
    }

    .conversation-meta span {
        color: #cbd5e1;
        margin: 0 4px;
    }

    .conversation-main .conversation-preview {
        border: 0;
        color: #334155;
        font-size: 14px;
        padding: 0;
    }

    .conversation-main small {
        color: #94a3b8;
        display: block;
        font-size: 12px;
    }

    .conversation-side {
        align-items: center;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .conversation-side small {
        color: #94a3b8;
        font-size: 11px;
        white-space: nowrap;
    }

    .unread-message-label {
        background: #f97316;
        border-radius: 999px;
        color: #fff;
        font-size: 10px;
        font-weight: 900;
        padding: 4px 8px;
        white-space: nowrap;
    }

    .conversation-side .open-conversation-btn {
        align-items: center;
        background: #f8fafc;
        border-radius: 10px;
        color: #334155;
        display: flex;
        font-size: 18px;
        height: 30px;
        justify-content: center;
        padding: 0;
        width: 30px;
    }

    @@media (max-width: 576px) {
        .rental-conversation-card {
            align-items: start;
            grid-template-columns: 42px minmax(0, 1fr);
            padding: 14px;
        }

        .conversation-avatar {
            border-radius: 12px;
            height: 42px;
            width: 42px;
        }

        .conversation-side {
            align-items: end;
            flex-direction: row;
            grid-column: 2;
            justify-content: space-between;
        }
    }
</style>
