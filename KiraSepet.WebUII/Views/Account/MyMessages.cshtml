@using KiraSepet.EntityLayer
@model List<ContactMessage>
<div class="container py-5"><h2>Mesajlarım</h2><p class="text-muted">Destek ekibiyle yazışmalarınız.</p>@if (TempData["UserReplySuccess"] != null) { <div class="alert alert-success">@TempData["UserReplySuccess"]</div> } @if (!Model.Any()) { <div class="alert alert-info">Henüz mesajınız yok.</div> } else { @foreach (var item in Model) { <div class="card shadow-sm mb-3"><div class="card-body"><h5>@item.Subject</h5><p><strong>Siz:</strong> @item.Message</p>@if (!string.IsNullOrWhiteSpace(item.AdminReply)) { <div class="alert alert-primary"><strong>Destek ekibi:</strong> @item.AdminReply</div><form asp-action="ReplyToAdmin" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><textarea name="reply" class="form-control mb-2" rows="3" placeholder="Yanıtınızı yazın" required></textarea><button class="btn btn-outline-primary" type="submit">Yanıt Gönder</button></form> } else { <small class="text-muted">Destek ekibinin yanıtı bekleniyor.</small> } @if (!string.IsNullOrWhiteSpace(item.UserReply)) { <div class="mt-3"><strong>Son yanıtınız:</strong> @item.UserReply</div> }</div></div> } }</div>
