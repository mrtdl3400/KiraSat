@using KiraSepet.EntityLayer
@model ContactMessage
@{ var info = ViewBag.ContactInfo as ContactInfo ?? new ContactInfo(); var isAdmin = Context.Session.GetString("UserRole") == "Admin"; }
<div class="container py-5"><h2>İletişim</h2><p class="text-muted">Soruların ve önerilerin için bize ulaşabilirsin.</p>
@if (TempData["ContactSuccess"] != null) { <div class="alert alert-success">@TempData["ContactSuccess"]</div> }
@if (TempData["ContactInfoSuccess"] != null) { <div class="alert alert-success">@TempData["ContactInfoSuccess"]</div> }
@if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
<div class="row g-4"><div class="col-md-4"><div class="card shadow-sm p-4 h-100"><h5>Destek Bilgileri</h5><p><strong>E-posta</strong><br />@info.Email</p><p><strong>Telefon</strong><br />@info.Phone</p><p class="mb-0"><strong>Çalışma saatleri</strong><br />@info.WorkingHours</p></div></div>
<div class="col-md-8">@if (isAdmin) { <div class="card shadow-sm p-4"><h5>Destek Bilgilerini Düzenle</h5><form asp-action="UpdateContactInfo" method="post">@Html.AntiForgeryToken()<div class="mb-3"><label class="form-label">E-posta</label><input name="Email" value="@info.Email" class="form-control" required /></div><div class="mb-3"><label class="form-label">Telefon</label><input name="Phone" value="@info.Phone" class="form-control" required /></div><div class="mb-3"><label class="form-label">Çalışma Saatleri</label><input name="WorkingHours" value="@info.WorkingHours" class="form-control" required /></div><button class="btn btn-primary" type="submit">Kaydet</button></form></div> } else if (Context.Session.GetString("UserEmail") != null) { <div class="card shadow-sm p-4"><h5>Mesaj Gönder</h5><form asp-action="Contact" method="post">@Html.AntiForgeryToken()<div class="row"><div class="col-md-6 mb-3"><label asp-for="Name" class="form-label">Ad Soyad</label><input asp-for="Name" class="form-control" required /></div><div class="col-md-6 mb-3"><label asp-for="Email" class="form-label">E-posta</label><input asp-for="Email" class="form-control" type="email" required /></div></div><div class="mb-3"><label asp-for="Subject" class="form-label">Konu</label><input asp-for="Subject" class="form-control" required /></div><div class="mb-3"><label asp-for="Message" class="form-label">Mesaj</label><textarea asp-for="Message" class="form-control" rows="5" required></textarea></div><button type="submit" class="btn btn-primary">Mesaj Gönder</button></form></div> } else { <div class="alert alert-info">Mesaj göndermek için giriş yapmalısınız.</div> }</div></div></div>
