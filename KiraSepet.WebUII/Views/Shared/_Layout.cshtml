@using KiraSepet.WebUII.Controllers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KiraSat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KiraSepet.WebUII.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">KiraSat</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto">
                        <div class="d-flex">
                            <li class="nav-item">
                                
                            </li>
                            

                        </div>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="urunDropdown" role="button" data-bs-toggle="dropdown">
                                Ürünler
                            </a>

                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="Index">Ürün Listesi</a></li>
                                <li><a class="dropdown-item" asp-controller="Product" asp-action="AddProduct">Ürün Ekle</a></li>
                                <div class="d-flex">


                                </div>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="kategoriDropdown" role="button" data-bs-toggle="dropdown">
                                Kategoriler
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Category" asp-action="Index">Kategori Listesi</a></li>
                                <li><a class="dropdown-item" asp-controller="Category" asp-action="AddCategory">Kategori Ekle</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">


                           

                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Cart/Index">
                                🛒 Sepet
                                @if (CartController.cartItems.Count > 0)
                                {
                                    <span class="badge bg-danger">
                                        @CartController.cartItems.Count
                                    </span>
                                }
                            </a>
                            
                           @{
    var userName = Context.Session.GetString("UserName") ?? "Guest";
    var favCount = FavoriteController.userFavorites.ContainsKey(userName)
        ? FavoriteController.userFavorites[userName].Count
        : 0;
}

<li class="nav-item">
    <a class="nav-link text-dark d-flex align-items-center gap-1" href="/Favorite/Index">
        ♡ Favoriler

        @if (favCount > 0)
        {
            <span class="badge bg-danger">@favCount</span>
        }
    </a>
</li>
    
                        
                        @if (Context.Session.GetString("UserEmail") == null)
                         {
                           

                                <a href="/Login/Index" class="btn btn-outline-primary me-2">
                                    Giriş Yap
                                </a>
                                <a href="/Register/Index" class="btn btn-primary">
                                    Kayıt Ol
                                </a>

                                <a href="/ForgotPassword/Index" class="btn btn-link">
                                    Şifremi Unuttum
                                </a>
                        
                       }
                      else
                      {
                            <li class="nav-item">
                                <span class="nav-link fw-bold text-primary">
                                    👋 Hoşgeldin, @Context.Session.GetString("UserName")
                                </span>

                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" href="/Login/Logout">
                                    Çıkış Yap
                                </a>
                            </li>
                     
                     }                     
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - KiraSepet.WebUII - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

                    


                           
                            

                    
                       