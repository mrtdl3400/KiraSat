+@{
    var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
    var favoriteCount = Context.Session.GetInt32("FavoriteCount") ?? 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KiraSat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KiraSepet.WebUII.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        
        <nav class="navbar navbar-expand-lg ks-navbar">
            <div class="container-fluid px-4">
                <a class="ks-brand" href="/Home/Index">
                    <span class="ks-logo">KS</span>
                    <span>KiraSat</span>
                </a>

                <form method="get" action="/Product/Index" class="ks-search">
                    <input type="text" name="p" placeholder="Ürün, marka veya kategori ara..." />
                    <button type="submit">Ara</button>
                </form>

                <div class="ks-menu">
                    <a href="/Product/Index?category=Elektronik">Elektronik</a>
                    <a href="/Product/Index?category=Mobilya">Mobilya</a>
                    <a href="/Product/Index?category=Spor">Spor</a>
                    <a href="/Favorite/Index" class="ks-count-link">
                   
                    Favoriler
                    @if (favoriteCount > 0)
                    {
                        <span class="ks-count-badge">@favoriteCount</span>
                    }

                    </a>

                
                <a href="/Cart/Index" class="ks-count-link">
                    Sepet
                    @if (cartCount > 0)
                    {
                        <span class="ks-count-badge">@cartCount</span>
                    }
                </a>

                    @if (Context.Session.GetString("UserEmail") == null)
                    {
                        <a href="/Login/Index" class="ks-login">Giriş Yap</a>
                        <a href="/Register/Index" class="ks-register">Kayıt Ol</a>
                    }

                    
                    else
                    {

                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                    <a href="/AdminBusiness/Index">İşletme Yönetimi</a>
                    }
                        <a href="/Notification/Index">Bildirimler</a>
                        <a href="/Business/Apply">İşletme Başvurusu</a>
                        <a href="/Order/Index">Siparişlerim</a>
                        <a href="/Login/Logout" class="ks-logout">Çıkış</a>
                    }
                </div>
            </div>
        </nav>
    </header>


    <div class="container">
   

        <main role="main" class="pb-3">
            @if (TempData["BusinessMessage"] != null)
            {
                <div class="alert alert-info mt-3">
                    @TempData["BusinessMessage"]
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
         &copy; 2026 - KiraSat
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)



        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


</body>
</html>


                    


                           
                            

                    
                       
