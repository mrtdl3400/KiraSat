@using KiraSepet.DataAccessLayer
@inject Context DbContext

@{
    var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
    var favoriteCount = Context.Session.GetInt32("FavoriteCount") ?? 0;

    var userEmail = Context.Session.GetString("UserEmail");
    var unreadNotificationCount = 0;
    var unreadMessageCount = 0;
    var rentalUnreadMessageCount = 0;
    var currentUser = string.IsNullOrWhiteSpace(userEmail)
        ? null
        : DbContext.AppUsers.FirstOrDefault(x => x.Email == userEmail);

    if (currentUser != null)
    {
        unreadNotificationCount = DbContext.AppNotifications
            .Count(x => x.UserId == currentUser.Id && !x.IsRead &&
                x.Title != "Yeni iletişim mesajı" &&
                x.Title != "Kullanıcı yanıtı" &&
                x.Title != "Destek yanıtı");

        rentalUnreadMessageCount = DbContext.RentalMessages.Count(message =>
!message.IsRead &&
message.SenderUserId != currentUser.Id &&
DbContext.RentalConversations.Any(conversation =>
conversation.Id == message.RentalConversationId &&
(conversation.TenantUserId == currentUser.Id ||
 conversation.OwnerUserId == currentUser.Id)));

        unreadMessageCount = currentUser.Role == "Admin"
            ? DbContext.ContactMessages.Count(x => !x.IsAdminRead)
            : DbContext.ContactMessages.Count(x => x.Email == userEmail && !x.IsUserRead && !string.IsNullOrWhiteSpace(x.AdminReply));
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KiraSat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KiraSepet.WebUII.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        
        <nav class="navbar navbar-expand-lg ks-navbar">
            <div class="container-fluid px-4">
                <a class="ks-brand" href="/Home/Index">
                    <span class="ks-logo">KS</span>
                    <span>KiraSat</span>
                </a>

                <form method="get" action="/Product/Index" class="ks-search">
                    <input type="text" name="p" placeholder="Ürün, marka veya kategori ara..." />
                    <button type="submit">Ara</button>
                </form>

                <div class="ks-menu">
                    <a href="/Product/Index?category=Elektronik">Elektronik</a>
                    <a href="/Product/Index?category=Mobilya">Mobilya</a>
                    <a href="/Product/Index?category=Spor">Spor</a>
                    <a href="/Favorite/Index" class="ks-count-link">
                   
                    Favoriler
                    @if (favoriteCount > 0)
                    {
                        <span class="ks-count-badge">@favoriteCount</span>
                    }

                    </a>

                
                <a href="/Cart/Index" class="ks-count-link">
                    Sepet
                    @if (cartCount > 0)
                    {
                        <span class="ks-count-badge">@cartCount</span>
                    }
                </a>

                    @if (Context.Session.GetString("UserEmail") == null)
                    {
                        <a href="/Login/Index" class="ks-login">Giriş Yap</a>
                        <a href="/Register/Index" class="ks-register">Kayıt Ol</a>
                    }

                    
                    else
                    {
                        @if (currentUser != null && DbContext.Businesses.Any(x => x.OwnerUserId == currentUser.Id && x.IsApproved))
                        {
                            <a href="/Seller/Dashboard" class="ks-business-apply">Satıcı Paneli</a>
                        }
                        else
                        {
                            <a href="/Business/Apply" class="ks-business-apply">İşletme Başvurusu</a>
                        }

                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                    <a href="/AdminBusiness/Index">İşletme Yönetimi</a>
                    }
                        <a href="/Notification/Index">
                            Bildirimler
                            @if (unreadNotificationCount > 0)
                            {
                                <span style="background:#dc3545; color:white; border-radius:50%; padding:2px 7px; font-size:12px; margin-left:4px;">
                                    @unreadNotificationCount
                                </span>
                            }
                        </a>
                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <a href="/Account/ContactMessages">Gelen Mesajlar @if (unreadMessageCount > 0) { <span class="ks-message-badge">@unreadMessageCount</span> }</a>
                        }
                        else
                        {
                            <a href="/Account/MyMessages">Mesajlarım @if (unreadMessageCount > 0) { <span class="ks-message-badge">@unreadMessageCount</span> }</a>
                        }
                        <a href="/Order/Index">Siparişlerim</a>
                        <a href="/RentalMessage/Index">
                        İlan Mesajlarım

                        @if (rentalUnreadMessageCount > 0)
                        {
                       <span class="ks-message-badge">
                       @rentalUnreadMessageCount
                       </span>
                       }
                       </a>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle"
                                    type="button"
                                    data-bs-toggle="dropdown">
                                Hesabım
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="/Account/Profile">
                                        Profilim
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="/Account/Settings">
                                        Hesap Ayarları
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="/Account/About">
                                        Hakkımızda
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="/Account/Contact">
                                        İletişim
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <a class="dropdown-item text-danger" href="/Login/Logout">
                                        Çıkış Yap
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>


    <div class="container">
   

        <main role="main" class="pb-3">
            @if (TempData["BusinessMessage"] != null)
            {
                <div class="alert alert-info mt-3">
                    @TempData["BusinessMessage"]
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
         &copy; 2026 - KiraSat
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)



        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


</body>
</html>


                    


                           
                            

                    
                       
